{
  "name": "@dhzh/eslint-config",
  "type": "module",
  "version": "1.25.2",
  "packageManager": "pnpm@10.31.0",
  "description": "tinywaves's ESLint config",
  "author": {
    "name": "Lyle Zheng",
    "email": "dhzhme@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/tinywaves/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinywaves/eslint-config"
  },
  "bugs": {
    "url": "https://github.com/tinywaves/eslint-config/issues"
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./bin/index.js",
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "scripts": {
    "build": "pnpm run typegen && tsup --clean --dts",
    "build:inspector": "pnpm run build && npx @eslint/config-inspector build",
    "dev": "pnpm run typegen && npx @eslint/config-inspector --config eslint.config.ts",
    "lint": "eslint",
    "lint-fix": "eslint --fix .",
    "prepack": "pnpm run build",
    "prepare": "simple-git-hooks",
    "release": "bumpp",
    "typecheck": "tsc --noEmit",
    "typegen": "tsx scripts/eslint-typegen.ts"
  },
  "peerDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "eslint": "^10.0.3"
  },
  "peerDependenciesMeta": {
    "@prettier/plugin-xml": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@unocss/eslint-config": "66.6.6",
    "ansis": "^4.2.0",
    "cac": "^7.0.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.2.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsonc": "^3.1.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-package-json": "^0.89.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-google-translate": "^0.1.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "eslint-plugin-toml": "^1.3.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-yml": "^3.3.1",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.4.0",
    "local-pkg": "^1.1.2",
    "toml-eslint-parser": "^1.0.3",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^2.0.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/types": "^8.56.1",
    "bumpp": "^11.0.1",
    "bundle-require": "^5.1.0",
    "eslint": "^10.0.3",
    "eslint-typegen": "^2.3.1",
    "lint-staged": "^16.3.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}

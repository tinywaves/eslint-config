{
  "name": "@dhzh/eslint-config",
  "type": "module",
  "version": "2.2.2",
  "description": "tinywaves's ESLint config",
  "author": {
    "name": "Lyle Zheng",
    "email": "dhzhme@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/tinywaves/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinywaves/eslint-config"
  },
  "bugs": {
    "url": "https://github.com/tinywaves/eslint-config/issues"
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^26.3.1",
      "onFail": "download"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": "./bin/index.js",
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "scripts": {
    "build": "pnpm run typegen && tsdown --clean --dts",
    "build:inspector": "pnpm run build && pnpm exec @eslint/config-inspector build",
    "dev": "pnpm run typegen && pnpm exec @eslint/config-inspector --config eslint.config.ts",
    "lint": "eslint",
    "lint-fix": "eslint --fix .",
    "prepack": "pnpm run build",
    "prepare": "simple-git-hooks",
    "release": "bumpp",
    "typecheck": "tsc --noEmit",
    "typegen": "tsx scripts/eslint-typegen.ts"
  },
  "peerDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "eslint": "^10.5.0"
  },
  "peerDependenciesMeta": {
    "@prettier/plugin-xml": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.9.1",
    "@eslint/js": "^10.0.1",
    "@manypkg/get-packages": "^3.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@unocss/eslint-config": "66.7.2",
    "ansis": "^4.3.1",
    "cac": "^7.0.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-google-translate": "^1.0.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-toml": "^1.4.0",
    "eslint-plugin-unicorn": "^68.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.4.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.6.0",
    "local-pkg": "^1.2.1",
    "toml-eslint-parser": "^1.0.3",
    "typescript-eslint": "^8.61.1",
    "vue-eslint-parser": "^10.4.1"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^3.0.4",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/node": "^24.13.2",
    "@typescript-eslint/types": "^8.61.1",
    "bumpp": "^11.1.0",
    "bundle-require": "^5.1.0",
    "changelogithub": "^14.0.0",
    "eslint": "^10.5.0",
    "eslint-typegen": "^2.3.1",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "eval \"$(fnm env)\" && pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
